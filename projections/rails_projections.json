{
  "app/models/indexers/*_indexer.rb": {
    "type": "indexer",
    "alternate": [
      "app/models/indexers/models/{}.rb"
    ]
  },
  "app/models/indexers/models/*.rb": {
    "type": "model_indexer",
    "alternate": [
      "app/models/indexers/{}_indexer.rb"
      ]
  },
  "app/models/*.rb": {
    "type": "model",
    "template": [
      "class {camelcase|capitalize}",
      "end"
    ],
    "alternate": [
      "spec/models/{}_spec.rb",
      "spec/factories/{plural}.rb"
    ]
  },
  "spec/models/*_spec.rb": {
    "type": "model_spec",
    "template": [
      "RSpec.describe {camelcase|capitalize} do",
      "  describe \"#xx\" do",
      "    let!(:yy) { create(:zzz) }",
      "    subject { create(:%S) }",
      "    context \"when something\"",
      "      it { expect(subject.xx).to eq(0) }",
      "    end",
      "  end",
      "end"
    ],
    "alternate": [
      "app/models/{}.rb"
    ]
  },
  "app/controllers/*_controller.rb": {
    "type": "controller",
    "alternate": [
      "spec/requests/{}_spec.rb",
      "app/views/{}",
      "app/models/abilities/{singular}_ability.rb"
    ]
  },
  "app/models/abilities/*_ability.rb": {
    "type": "ability",
    "alternate": [
      "app/controllers/{plural}_controller.rb"
    ]
  },
  "app/views/*": {
    "type": "view",
    "alternate": [
      "app/controllers/{}_controller.rb"
    ]
  },
  "spec/requests/*_spec.rb": {
    "type": "controller_spec",
    "alternate": [
      "app/controllers/{}_controller.rb"
    ]
  },
  "app/controllers/staff/*_controller.rb": {
    "type": "staff_controller",
    "alternate": [
      "spec/requests/staff/{}_spec.rb",
      "app/serializers/staff/{singular}_serializer.rb"
    ]
  },
  "app/serializers/staff/*_serializer.rb": {
    "type": "serializer",
    "alternate": [
      "app/controllers/staff/{plural}_controller.rb",
      ""
    ]
  },
  "spec/requests/staff/*_spec.rb": {
    "type": "staff_controller_spec",
    "alternate": [
      "app/controllers/staff/{}_controller.rb"
    ]
  },
  "lib/middleware/*.rb": {
    "type": "middleware",
    "alternate": []
  },
  "spec/factories/*.rb": {
    "type": "factory",
    "alternate": [
      "app/models/{singular}.rb"
    ]
  },
  "features/step_definitions/*_steps.rb": {
    "type": "feature_steps",
    "alternate": []
  },
  "features/staff/*": {
    "type": "staff_feature",
    "alternate": []
  },
  "features/*": {
    "type": "feature",
    "alternate": []
  }
}
