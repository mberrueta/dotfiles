# kill_ports 3000
function kill_ports() {
  # kill $(lsof -ti:($1))
  kill $(lsof -ti:$1)
}

# git_restore1 3000
function git_restore1() {
  echo "git restore --source master~1 $1"
  git restore --source master~1  $1
}

