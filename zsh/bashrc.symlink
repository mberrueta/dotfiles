#!/bin/sh

alias go=richgo
alias coauth='printf "Co-authored-by: %s" "$(git log --pretty=format:"%an <%ae>" -1000 | sort | uniq | fzf)" | pbcopy'
alias ls="ls -la"
alias k="kubectl"
alias weather='curl  wttr.in/buenos_aires' # weather
alias git_log="git log --graph --pretty=format:'%C(auto)%h%d (%ci) %cn <%ce> %s'"
alias git_files_log="git log --name-status --author=mberrueta | sort | uniq | grep -w '[M|A|D]'"
alias git_remove_branches="git branch -D `git branch --merged | grep 'VA*' | xargs`"
alias ..='cd ..'
alias grep='grep --color=auto'
alias tls='tmux ls'
alias tns='tmux new-session -s' # tmux new -s myname
alias tat='tmux attach -t' # tmux a -t myname
alias tkt='tmux kill-session -t' # tmux kill-session -t myname
alias open_api=~/.config/dotfiles/tmux/api_layout.sh
alias open_api_scripts=~/.config/dotfiles/tmux/scripts_layout.sh
alias vi=nvim
alias vim=nvim
alias gp='git pull --all'
alias gcm='git checkout master'
alias be="bundle exec"
alias bec="be cucumber"
alias ber="be rspec --format documentation"
alias ber_routes="be rake routes"
alias berr=ber_routes
alias ber_console="be rails console"
alias berc=ber_console
alias ber_server="be rails server -b 0.0.0.0"
alias bers=ber_server
alias ber_migrate="be rake db:migrate:all"
alias berm=ber_migrate
alias ber_seed="be rake db:seed"
alias seed=ber_seed
alias ber_jobs="be rake eft3:recover_delayed_mq jobs:workoff"
alias berj=ber_jobs
alias rebuild_db="be rake db:drop db:create db:structure:load db:migrate:all db:seed"
alias upload=transfer
alias set_env_var="export $(cat ./.env | sed 's/#.*//g' | xargs )"
alias kill_mica=ps awwwwux | grep mica | grep loginwindow | grep -v grep | awk "{ print \$2 }"
alias kill_pe=ps awwwwux | grep pechy | grep loginwindow | grep -v grep | awk "{ print \$2 }"

# Add RVM to PATH for scripting. Make sure this is the last PATH variable change.
export PATH="$PATH:$HOME/go/bin"
export PATH="$PATH:$HOME/bin"
export PATH="$PATH:$HOME/code/platform-tools"
export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
export GO111MODULE=on  # Enable module mode
export GOPATH=~/go
export PATH="$PATH:$GOPATH/bin"
export PATH="$PATH:$HOME/bin/nvim/bin/"
# export COLUMNS=1000
# export TERM=xterm-color
export GREP_OPTIONS='--color=auto' GREP_COLOR='1;32'
export CLICOLOR=1
export LSCOLORS=ExFxCxDxBxegedabagacad

export VI_MODE_SET_CURSOR=true

# [ -f ~/.fzf.bash ] && source ~/.fzf.bash
[ -f ~/.priv_bashrc ] && source ~/.priv_bashrc
[ -f ~/etc/profile.d/bash_completion.sh ] && ~/etc/profile.d/bash_completion.sh

set histdup='all' # duplicate entries in the history

random() {
 shuf -i 0-9 -n 1
}

function load_env() {
  export $(cat ./.env | sed 's/#.*//g' | xargs )
}

function backup_wd() {
  # r=$(random)
  pwd=$(pwd)
  directory=$(basename $PWD)
  rsync -a . "/tmp/$directory/"
  cd "/tmp/$directory"
  gp
  export $(cat ./.env | sed 's/#.*//g' | xargs )
}

# gem install iStats
function stats() {

  ps aux | sort -nrk 3,3 | head -n 5
watch "ps aux | sort -nrk 3,3 | head -n 5"

  # htop -d 50 -u | head -n 12
  top -b -n 1 | head -n 12
ps ahux --sort=-c | awk 'NR<=5{printf"%s %6d %s\n",$3,$2,$11}'
  istats
  htop
  top #  real-time sorted display of running processes such as memory and CPU usage
  iostat #  I/O summary statistics for terminal, device and CPU operations
  vm_stat #  Mach virtual memory statistics
  diskutil list #  disk/volume capacity
  df #  used/free space on mounted partitions
  sudo fs_usage #  real-time file activity for both disk and network
  nettop #  updated information about the network (a bit like top for net I/O)
  w #  who is logged in and what they are doing; plus a brief system load summary
  ifconfig and ipconfig #  network interface and IP protocol details
}

